# ── Wallet ────────────────────────────────────────────────────────────────────
# Your deployer private key (with 0x prefix). Must be funded with STT on Somnia Testnet.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Network ───────────────────────────────────────────────────────────────────
# Somnia Testnet RPC (default works; override if using a dedicated node)
SOMNIA_RPC=https://dream-rpc.somnia.network

# ── Somnia Platform ───────────────────────────────────────────────────────────
# The deployed Somnia Agentic Platform contract on testnet
PLATFORM_ADDRESS=0x037Bb9C718F3f7fe5eCBDB0b600D607b52706776

# ── Agent IDs (from https://agents.testnet.somnia.network/) ──────────────────
# JSON API agent — already known
JSON_API_AGENT_ID=13174292974160097713

# LLM Parse Website agent — look this up in the Somnia Agent Explorer
LLM_PARSE_AGENT_ID=YOUR_LLM_PARSE_AGENT_ID

# LLM Inference agent — look this up in the Somnia Agent Explorer
LLM_INFER_AGENT_ID=YOUR_LLM_INFER_AGENT_ID

# ── Deployed Addresses (populated after deployment) ───────────────────────────
ARIA_REGISTRY_ADDRESS=
ARIA_GATED_DAO_ADDRESS=
ARIA_LENDING_MARKET_ADDRESS=

# ── Optional ──────────────────────────────────────────────────────────────────
REPORT_GAS=false
